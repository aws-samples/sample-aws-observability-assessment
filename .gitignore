# Ignore local files directory and all contents
localfiles/

# Assessment output files (may contain account-specific data)
sample-result/*
!sample-result/observability_assessment_sample.html
!sample-result/org-scan-sample/
assessment-result/

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Ruff cache
.ruff_cache/

# ASH: only track the config file, ignore scan output and everything else
.ash/*
!.ash/.ash.yaml

# IDE configurations
.kiro/
.vscode/



DESIGN_SYSTEM_TEMPLATE.MD
